# Environment Configuration - PRODUCTION HARDENED
# CRITICAL: Generate secure secrets before deployment

# Database Configuration
DATABASE_URL=postgresql+asyncpg://finuser:CHANGE_ME_STRONG_PASSWORD@postgres:5432/financedb

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Authentication (CRITICAL - MUST CHANGE)
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32_MINIMUM_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15

# Data Encryption (CRITICAL - MUST CHANGE)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32_FOR_DATA_ENCRYPTION

# Internal Service Authentication (CRITICAL - MUST CHANGE)
# Generate: openssl rand -urlsafe 32
INTERNAL_SERVICE_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_URLSAFE_32

# OpenRouter API (Optional - fallback to statistical model)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Service URLs
TRANSACTIONS_URL=http://transactions:8001
AI_URL=http://ai:8002

# Admin Configuration (comma-separated)
ADMIN_EMAILS=admin@yourdomain.com

# Environment
ENVIRONMENT=production
DEBUG=false

# CORS Configuration (comma-separated, NO WILDCARDS)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Trusted Hosts (comma-separated)
TRUSTED_HOSTS=yourdomain.com,app.yourdomain.com,api.yourdomain.com

# Admin IP Whitelist (comma-separated, optional)
ADMIN_IP_WHITELIST=

# Observability
JAEGER_HOST=jaeger
JAEGER_PORT=6831

# Metrics
PROMETHEUS_ENABLED=true

# Rate Limiting
GLOBAL_RATE_LIMIT_PER_IP=1000
GLOBAL_RATE_LIMIT_WINDOW=60

# Security
HTTPS_REDIRECT_ENABLED=true
MAX_REQUEST_SIZE=1048576
