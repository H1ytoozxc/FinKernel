# Local development environment
# Copy from .env.example and customize

DATABASE_URL=postgresql+asyncpg://finuser:finpass123@postgres:5432/financedb
REDIS_URL=redis://redis:6379/0

# JWT - Generate with: openssl rand -hex 32
JWT_SECRET_KEY=dev_secret_key_only_for_local_development_change_in_production_32chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=10080

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Service URLs
TRANSACTIONS_URL=http://transactions:8001
AI_URL=http://ai:8002

# Admin emails
ADMIN_EMAILS=admin@example.com,dev@example.com

# Environment
ENVIRONMENT=development
DEBUG=true
